# Copy to .env.local and fill in your own keys

ELEVENLABS_API_KEY=sk_...
GEMINI_API_KEY=AIza...
VERCEL_TOKEN=vcp_...
RESEND_API_KEY=re_...

# Generate with: openssl rand -hex 32
JWT_SECRET=

# The from-address for auth emails. Defaults to Resend's onboarding sender if unverified.
AUTH_FROM_EMAIL=Yap <onboarding@resend.dev>

# Optional override for the magic-link host. Auto-derived from the request otherwise.
# PUBLIC_APP_URL=https://yap.example.com
